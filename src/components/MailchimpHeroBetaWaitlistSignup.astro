<div class="bg-primary-600/90 rounded-lg shadow-lg p-6 md:p-8">
  <h3 class="text-white text-xl font-semibold mb-4">Join the Chiron Beta</h3>
  <p class="text-primary-100 mb-6">Get the latest training insights and early access updates.</p>

  <form
    action="https://chironapp.us21.list-manage.com/subscribe/post?u=e0c9d80e1958ea530aa50f077&id=28fa8a4cee&f_id=00bf93e6f0"
    method="post"
    id="mc-embedded-subscribe-form"
    name="mc-embedded-subscribe-form"
    class="validate"
    target="_blank"
    novalidate
  >
    <div id="mce-responses" class="mb-6">
      <div class="response hidden p-4 rounded-md bg-red-50 border border-red-200" id="mce-error-response">
        <p class="text-red-600 text-sm"></p>
      </div>
      <div class="response hidden p-4 rounded-md bg-green-50 border border-green-200" id="mce-success-response">
        <p class="text-green-600 text-sm"></p>
      </div>
    </div>

    <div class="mb-6">
      <label for="mce-FNAME" class="block text-sm font-medium text-white mb-2">
        First Name
      </label>
      <input
        type="text"
        name="FNAME"
        id="mce-FNAME"
        class="w-full px-4 py-3 rounded-lg text-black placeholder-gray-500 focus:ring-2 focus:ring-primary-300 focus:border-transparent outline-none transition-colors bg-white"
        placeholder="Enter your first name"
      />
    </div>

    <div class="mb-8">
      <label for="mce-EMAIL" class="block text-sm font-medium text-white mb-2">
        Email Address <span class="text-red-400">*</span>
      </label>
      <input
        type="email"
        name="EMAIL"
        id="mce-EMAIL"
        required
        class="w-full px-4 py-3 rounded-lg text-black placeholder-gray-500 focus:ring-2 focus:ring-primary-300 focus:border-transparent outline-none transition-colors bg-white"
        placeholder="Enter your email address"
      />
    </div>

    <div hidden>
      <input type="hidden" name="tags" value="3018884" />
    </div>

    <div style="position: absolute; left: -5000px;" aria-hidden="true">
      <input type="text" name="b_e0c9d80e1958ea530aa50f077_28fa8a4cee" tabindex="-1" value="" />
    </div>

    <div class="text-center">
      <button
        type="submit"
        name="subscribe"
        id="mc-embedded-subscribe"
        class="w-full bg-white text-primary-600 font-semibold py-4 px-8 rounded-lg hover:bg-primary-50 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors"
      >
        Join the Waitlist
      </button>
    </div>

    <p class="text-center text-xs text-primary-100 mt-4">
      <span class="text-red-400">*</span> Required field
    </p>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('mc-embedded-subscribe-form');
    const errorResponse = document.getElementById('mce-error-response');

    if (!form) return;

    form.addEventListener('submit', function(e) {
      const email = document.getElementById('mce-EMAIL') as HTMLInputElement | null;

      if (email && !email.value) {
        e.preventDefault();
        showError('Please enter your email address.');
        return;
      }

      if (email && !isValidEmail(email.value)) {
        e.preventDefault();
        showError('Please enter a valid email address.');
        return;
      }

      hideError();

      const submitButton = document.getElementById('mc-embedded-subscribe') as HTMLButtonElement | null;
      if (submitButton) {
        submitButton.textContent = 'Subscribing...';
        submitButton.disabled = true;
      }
    });

    function isValidEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }

    function showError(message) {
      if (!errorResponse) return;
      const messageElement = errorResponse.querySelector('p');
      if (messageElement) messageElement.textContent = message;
      errorResponse.classList.remove('hidden');
    }

    function hideError() {
      if (errorResponse) errorResponse.classList.add('hidden');
    }
  });
</script>
