---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entry = await getEntry('legal', 'privacy/latest');
const { Content } = await entry.render();
---

<BaseLayout
  title="Privacy Policy - Chiron"
  description="Learn about how Chiron collects, uses, and protects your personal information in accordance with Australian privacy laws."
>
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg prose-primary max-w-none">
        <div class="bg-white rounded-lg shadow-md p-8">
          <Content />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>