---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Beta Tester Guide - Chiron"
  description="Getting started guide for Chiron beta testers"
>
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 text-center">
        Beta Tester Guide
      </h1>
      <p class="text-xl text-gray-600 mb-12 text-center">
        Welcome to the Chiron beta program! This guide will help you get started and make the most of your testing experience.
      </p>

      <!-- What is Chiron -->
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">What is Chiron?</h2>
        <p class="text-gray-700 mb-4">
          Chiron is your all-in-one training companion for endurance athletes. It helps you plan, track, and analyze your training to reach your performance goals.
        </p>
        <p class="text-gray-700">
          The beta program is evaluating core athlete features with a small group of close training partners. Your feedback will shape how Chiron helps runners train smarter.
        </p>
      </div>

      <!-- Getting Started -->
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Getting Started</h2>
        <ol class="space-y-4 text-gray-700">
          <li class="flex">
            <span class="font-bold text-primary-600 mr-3">1.</span>
            <span><strong>Register with your access code</strong></span>
          </li>
          <li class="flex">
            <span class="font-bold text-primary-600 mr-3">2.</span>
            <span><strong>Connect your Strava account</strong> — your recent activities will sync automatically</span>
          </li>
          <li class="flex">
            <span class="font-bold text-primary-600 mr-3">3.</span>
            <span><strong>Explore the features below</strong></span>
          </li>
        </ol>
      </div>

      <!-- Core Features -->
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Core Features to Try</h2>
        <div class="space-y-4 text-gray-700">
          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="font-bold text-gray-900 mb-2">Connect Strava</h3>
            <p>Your training history syncs automatically, giving Chiron the data it needs to show your progress</p>
          </div>

          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="font-bold text-gray-900 mb-2">Create an Event</h3>
            <p>Add a race or event you're training for and set your goals</p>
          </div>

          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="font-bold text-gray-900 mb-2">Build Your Workout Library</h3>
            <p>Create reusable workouts and schedule them to your training week</p>
          </div>

          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="font-bold text-gray-900 mb-2">Plan Your Training Week</h3>
            <p>Build out a week of structured training in the schedule</p>
          </div>

          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="font-bold text-gray-900 mb-2">Review Your Training Progress</h3>
            <p>See what you completed vs planned and track consistency over time</p>
          </div>

          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="font-bold text-gray-900 mb-2">Explore Performance Benchmarks and Charts</h3>
            <p>Check performance benchmarks and workout charts to see how you're progressing</p>
          </div>
        </div>
      </div>

      <!-- Known Limitations -->
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Known Limitations</h2>

        <div class="mb-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">Athlete Features Not Yet Available (Coming Soon)</h3>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 text-gray-700">
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Notifications</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Workout splits</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>COROS integration</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Garmin integration</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Training load analysis</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Assistant Coach AI planning & analysis</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Workout builder</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Performance predictor</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">•</span>
              <span>Strength exercise library</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-900 mb-3">Supported Devices</h3>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-center">
              <span class="text-green-600 font-bold mr-2">✅</span>
              <span>iOS</span>
            </li>
            <li class="flex items-center">
              <span class="text-green-600 font-bold mr-2">✅</span>
              <span>Web (limited)</span>
            </li>
            <li class="flex items-center">
              <span class="text-gray-400 mr-2">❌</span>
              <span class="text-gray-500">Android — not yet supported</span>
            </li>
            <li class="flex items-center">
              <span class="text-gray-400 mr-2">❌</span>
              <span class="text-gray-500">Desktop web — not yet supported</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Feedback -->
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">How to Give Feedback</h2>
        <p class="text-gray-700 mb-4">
          Use the support form at <a href="https://www.chironapp.com/support-center/contact" class="text-primary-600 hover:text-primary-700 underline">chironapp.com/support-center/contact</a>.
        </p>

        <h3 class="text-lg font-semibold text-gray-900 mb-3">Useful Feedback Includes:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex items-start">
            <span class="text-primary-600 mr-2">•</span>
            <span>What you were trying to do</span>
          </li>
          <li class="flex items-start">
            <span class="text-primary-600 mr-2">•</span>
            <span>What you expected to happen</span>
          </li>
          <li class="flex items-start">
            <span class="text-primary-600 mr-2">•</span>
            <span>What actually happened</span>
          </li>
          <li class="flex items-start">
            <span class="text-primary-600 mr-2">•</span>
            <span>Your device and iOS version</span>
          </li>
        </ul>
      </div>

      <!-- Support Link -->
      <div class="bg-gray-50 rounded-lg p-8 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Need Help?</h2>
        <p class="text-gray-600 mb-6">
          Visit our support center for more resources or to contact us.
        </p>
        <a
          href="/support-center"
          class="inline-block bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-700 transition-colors"
        >
          Support Center
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
