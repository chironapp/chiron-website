---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Support Center"
  description="Find answers to common questions or contact us for help with Chiron."
>
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 text-center">
        Support Center
      </h1>
      <p class="text-xl text-gray-600 mb-12 text-center">
        Find answers below, or contact us if you need more help.
      </p>

      <!-- Help Documentation Section -->
      <div class="bg-white rounded-lg shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Help Documentation</h2>

        <div class="space-y-6">
          <div class="border-l-4 border-primary-600 pl-4">
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Getting Started</h3>
            <ul class="space-y-2">
              <li>
                <a href="/support-center/beta-guide" class="text-primary-600 hover:text-primary-700 hover:underline">
                  Beta Tester Guide
                </a>
                <p class="text-sm text-gray-600 mt-1">Essential guide for beta testers to get started with Chiron</p>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Contact Section -->
      <div class="bg-gray-50 rounded-lg p-8 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Still need help?</h2>
        <p class="text-gray-600 mb-6">
          Can't find what you're looking for? Get in touch with our team.
        </p>
        <a
          href="/support-center/contact"
          class="inline-block bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-700 transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
